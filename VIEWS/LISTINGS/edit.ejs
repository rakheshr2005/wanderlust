<% layout('layouts/boilerplate') %>

<div class="row mt-3">
    <div class="col-8 offset-2" >
<body>
     <h3>Edit Your Listing</h3>
    <form method="post" action="/listings/<%= listing._id %>?_method=PUT">

        <div class="mb-3">
        <label for="title" class="label-control">Title</label>
        <input type="text" name="listing[title]" value="<%= listing.title  %>" id="title" class="form-control">
        </div>

        <div class="mb-3">
            <label for="description" class="label-control">Description</label>
                <textarea name="listing[description]" id="description" class="form-control"><%=listing.description%></textarea>
        </div>

        <div class="mb-3">
            <label for="image" class="label-control">Image Link</label>
            <input type="text" name="listing[image][url]" value="<%= listing.image.url  %>" id="image" class="form-control">
        </div>
<div class="row">
        <div class="mb-3 col-md-4">
            <label for="price" class="label-control">Price</label>
            <input type="number" name="listing[price]" value="<%= listing.price  %>" id="price" class="form-control">
        </div>

        <div class="mb-3 col-md-8">
            <label for="country" class="label-control">country</label>
            <input type="text" name="listing[country]" value="<%= listing.country  %>" id="country" class="form-control">
        </div>
</div>
        <div class="mb-3">
            <label for="location" class="label-control">Location</label>
            <input type="text" name="listing[location]" id="location" value="<%= listing.location  %>" class="form-control">
        </div>
        <button class="btn btn-dark edit-btn mt-3">Edit</button>
    </form>
    
</body>
  </div>
</div>