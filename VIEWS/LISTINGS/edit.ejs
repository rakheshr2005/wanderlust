<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderLust</title> 
</head>
<body>
     <h3>Edit Your Listing</h3>
    <form method="post" action="/listings/<%= listing._id %>?_method=PUT">
        <input type="text" name="listing[title]" value="<%= listing.title  %>" id="title" ><br><br>
        <textarea name="listing[description]" id="description" ><%=listing.description%></textarea><br><br>
        <input type="text" name="listing[image]" value="<%= listing.image  %>" id="image"><br><br>
        <input type="number" name="listing[price]" value="<%= listing.price  %>" id="price" ><br><br>
        <input type="text" name="listing[location]" id="location" value="<%= listing.location  %>"><br><br>
        <input type="text" name="listing[country]" value="<%= listing.country  %>" id="country">
        <button>Edit</button>
    </form>
</body>
</html>